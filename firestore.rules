rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allows anyone who is logged in to read/write user profiles
    match /users/{userId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth != null && (
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status'])) ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner')
      );
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }
    
    // Business data access
    match /businesses/{businessId} {
      allow read, write: if request.auth != null;
    }
    
    // Assessment data
    match /assessments/{id} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }
    
    // Products collection
    match /products/{id} {
      allow read, write: if request.auth != null;
    }
    
    // Customers collection
    match /customers/{id} {
      allow read, write: if request.auth != null;
    }
    
    // Invoices collection
    match /invoices/{id} {
      allow read, write: if request.auth != null;
    }
    
    // Tasks collection
    match /tasks/{id} {
      allow read, write: if request.auth != null;
    }
    
    // Quotations collection
    match /quotations/{id} {
      allow read, write: if request.auth != null;
    }

    // Orders collection
    match /orders/{id} {
      allow read, write: if request.auth != null;
    }

    // Vendors collection
    match /vendors/{id} {
      allow read, write: if request.auth != null;
    }

    // Purchases collection
    match /purchases/{id} {
      allow read, write: if request.auth != null;
    }

    // Join Requests collection
    match /joinRequests/{id} {
      allow create: if true; // Unauthenticated users can create requests
      allow read, update, delete: if request.auth != null; // Owners manage them
    }

    // Attendance collection
    match /attendance/{id} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        resource.data.staffId == request.auth.uid ||
        resource.data.businessId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId
      );
      allow update: if request.auth != null && (
        resource.data.staffId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'staff'
      );
    }
  }
}
